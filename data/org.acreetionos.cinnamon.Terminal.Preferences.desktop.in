[Desktop Entry]
Categories=GNOME;GTK;System;TerminalEmulator;
Comment=Configure the command line
DBusActivatable=false
Exec=cinnamon-terminal --preferences
Icon=org.acreetionos.cinnamon.Terminal.Preferences
Keywords=shell;prompt;command;commandline;cmd;
Name=Terminal Preferences
NoDisplay=true
SingleMainWindow=true
StartupNotify=true
StartupWMClass=Gnome-terminal-preferences
TryExec=cinnamon-terminal
Type=Application
