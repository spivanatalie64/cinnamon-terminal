{
  "id": "org.acreetionos.cinnamon.Terminal",
  "runtime": "org.gnome.Platform",
  "runtime-version": "47",
  "sdk": "org.gnome.Sdk",
  "command": "cinnamon-terminal",
  "finish-args": [
    "--share=ipc",
    "--socket=wayland",
    "--socket=fallback-x11",
    "--socket=pulseaudio",
    "--share=network",
    "--device=dri",
    "--filesystem=host",
    "--filesystem=/tmp",
    "--talk-name=org.acreetionos.cinnamon.Terminal",
    "--talk-name=org.gnome.Shell",
    "--talk-name=org.freedesktop.Flatpak",
    "--talk-name=org.freedesktop.secrets",
    "--own-name=org.acreetionos.cinnamon.Terminal.*",
    "--env=GSETTINGS_SCHEMA_DIR=/app/share/glib-2.0/schemas"
  ],
  "cleanup": [
    "/include",
    "/lib/pkgconfig",
    "/man",
    "/share/doc",
    "/share/gtk-doc",
    "/share/man",
    "/share/pkgconfig",
    "*.la",
    "*.a"
  ],
  "modules": [
    {
      "name": "vte4",
      "buildsystem": "meson",
      "config-opts": [
        "-Dgtk3=false",
        "-Dgtk4=true",
        "-Dgir=false",
        "-Dvapi=false",
        "-Ddocs=false"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://download.gnome.org/sources/vte/0.84/vte-0.84.0.tar.xz",
          "sha256": "0414e31583836aeb7878da25f67c515f7e8879917ecc37c92e26b83e8d8fc3e3"
        }
      ]
    },
    {
      "name": "cinnamon-terminal",
      "buildsystem": "meson",
      "config-opts": [
        "-Dbuildtype=release",
        "-Ddocs=true",
        "-Dnautilus_extension=false",
        "-Dsearch_provider=true"
      ],
      "sources": [
        {
            "type": "git",
            "url": "https://gitlab.acreetionos.org/acreetionos-code/cinnamon-terminal.git",
            "commit": "ce7c0863ac41cdc6bb349cdf427c04a10a76d18f"
        }
      ]
    }
  ]
}
